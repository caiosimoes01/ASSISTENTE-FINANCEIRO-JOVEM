# Variáveis de ambiente — copie para .env e preencha com seus valores reais
# NUNCA comite o arquivo .env com valores reais

# Firebase Configuration
VITE_FIREBASE_API_KEY=your_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=your_project_id.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project_id.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=your_app_id

# BRAPI (dados de ativos brasileiros) — https://brapi.dev/
VITE_BRAPI_TOKEN=your_brapi_token_here

# Banco Central SGS (não requer token para endpoints públicos)
VITE_BACEN_SGS_BASE_URL=https://api.bcb.gov.br/dados/serie/bcdata.sgs
